# Copy this file to .env and fill in real values. Never commit .env.

# Shared HMAC secret — Autonoma uses this to sign requests and you use it to
# verify them. Generate with:  openssl rand -hex 32
AUTONOMA_SHARED_SECRET=replace-with-a-32-byte-hex-secret

# Postgres connection string used by src/handlers.js.
DATABASE_URL=postgres://user:pass@localhost:5432/mydb

# Optional: override the default port (3000).
# PORT=3000
